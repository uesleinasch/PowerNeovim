# Backups gerados pelo próprio PowerNeovim ao linkar arquivos reais
*.pnbak.*

# Tarballs gerados por `powerneovim share`
*.tar.gz
*.tgz

# Personalização local (não compartilhada)
home.local/

# Estado runtime do Neovim (caso alguém rode nvim dentro do repo)
.lazy/
.local/

# Kitty: estado runtime da sessão e cache do save-session.py (não versionar)
home/.config/kitty/last-session.kitty
home/.config/kitty/__pycache__/

# Editores
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db
