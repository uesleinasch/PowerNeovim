# ~/.zshrc.local — personalização específica da máquina/usuário.
# Copie este arquivo para ~/.zshrc.local e edite à vontade.
# Este arquivo NÃO é versionado pelo PowerNeovim e nunca é tocado pelo install.

# ----- Identidade / aliases pessoais -----
# Exemplos extraídos do ambiente original (descomente o que for útil):

# alias jactonet='cd ~/vpn && sudo openvpn --config vpn.ovpn'
# alias dbeaver-max="snap run dbeaver-ce -vmargs -Xms512m -Xmx1096m"

