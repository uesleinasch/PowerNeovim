show_all() {
  show_header
  section_leader
  section_modes
  section_motion
  section_select
  section_edit
  section_textobj
  section_registers
  section_replace
  section_prontos
  section_marks
  section_macros
  section_buffers
  section_windows
  section_files
  section_search
  section_lsp
  section_diag
  section_git
  section_term
  section_harpoon
  section_flash
  section_surround
  section_comments
  section_session
  section_ui
  section_which
  section_packs
  section_misc
  printf "\n${C5}  Filtre uma seção: ${B}myastro <leader|modes|motion|select|edit|textobj|registers|replace|prontos|marks|macros|buffers|windows|files|search|lsp|diag|git|term|harpoon|flash|surround|comments|session|ui|which|packs|misc>${R}\n\n"
}

case "${1:-all}" in
  leader)             show_header; section_leader ;;
  modes|mode)         show_header; section_modes ;;
  motion|move)        show_header; section_motion ;;
  select|visual|sel)  show_header; section_select ;;
  edit|editing|yank|paste|copy|cut) show_header; section_edit ;;
  textobj|textobjects|to) show_header; section_textobj ;;
  registers|register|regs|reg) show_header; section_registers ;;
  replace|substitute|sub) show_header; section_replace ;;
  prontos|recipes|whole|file|all-file|cheats) show_header; section_prontos ;;
  marks|mark|jump|jumps) show_header; section_marks ;;
  macros|macro|repeat) show_header; section_macros ;;
  buffers|buf)        show_header; section_buffers ;;
  windows|win|splits) show_header; section_windows ;;
  files|file|tree)    show_header; section_files ;;
  search|find)        show_header; section_search ;;
  lsp)                show_header; section_lsp ;;
  diag|trouble)       show_header; section_diag ;;
  git)                show_header; section_git ;;
  term|terminal)      show_header; section_term ;;
  harpoon)            show_header; section_harpoon ;;
  flash|motion)       show_header; section_flash ;;
  surround)           show_header; section_surround ;;
  comments|comment|todo) show_header; section_comments ;;
  session|sessions)   show_header; section_session ;;
  ui|toggle|toggles)  show_header; section_ui ;;
  which|whichkey)     show_header; section_which ;;
  packs|pack|plugins) show_header; section_packs ;;
  misc)               show_header; section_misc ;;
  -h|--help|help)
    cat <<EOF
myastro — guia de atalhos do AstroNvim

Uso:
  myastro                  # exibe tudo
  myastro <seção>          # filtra uma seção

Seções:
  leader      Leader, descoberta e which-key
  modes       modos do vim (Normal, Insert, Visual, Replace, Cmd)
  motion      movimento de cursor (h/j/k/l, w, gg, f{c}, …)
  select      seleção visual (v, V, Ctrl-v) e ações sobre seleção
  edit        yank / delete / change / paste / undo / indent
  textobj     text objects (iw, aw, i", ip, if, ac …)
  registers   registers ("a, "+, "0, "_, :reg …)
  replace     :substitute, &, modo R, search&replace no projeto
  prontos     comandos prontos (arquivo inteiro): :%y, gg=G, ggVG…
  marks       marks (m{a}, '{a}, jumplist) + changelist
  macros      gravar (q{r}) e executar (@{r}) macros, repetir (.)
  buffers     navegar / fechar / reordenar buffers
  windows     splits do nvim (criar/navegar/redimensionar)
  files       neo-tree e abrir arquivos
  search      buscas (arquivos, grep, símbolos, help)
  lsp         LSP (gd, K, rename, code action, format…)
  diag        diagnostics + Trouble
  git         gitsigns (hunks, stage, blame, diff)
  term        toggleterm (terminal interno)
  harpoon     marcações rápidas (Space Space)
  flash       motion s/S e remote flash
  surround    ys/cs/ds para envolver / trocar / remover
  comments    gcc, gc{motion}, todo-comments
  session     resession (salvar/restaurar sessões)
  ui          toggles (wrap, spell, números, diagnósticos…)
  which       which-key (menu por prefixo)
  packs       packs/comunidade ativos
  misc        :Lazy, :Mason, health, save/quit
EOF
    ;;
  all|*) show_all ;;
esac
