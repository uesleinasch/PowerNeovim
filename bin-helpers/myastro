section_diag() {
  title "Diagnostics (Trouble)"
  key "]d  /  [d"             "próximo / anterior diagnóstico"
  key "]e  /  [e"             "próximo / anterior erro"
  key "<Leader>ld"            "diagnostic float (linha atual)"
  key "<Leader>xx"            "Trouble: diagnostics workspace"
  key "<Leader>xX"            "Trouble: diagnostics do buffer"
  key "<Leader>xs"            "Trouble: símbolos do documento"
  key "<Leader>xl"            "Trouble: definições/refs do LSP"
  key "<Leader>xL"            "Trouble: location list"
  key "<Leader>xQ"            "Trouble: quickfix list"
  key "<Leader>xT"            "Trouble: todo-comments"
  note "Trouble = lista navegável; q sai, r recarrega, ? ajuda"
}

section_git() {
  title "Git (gitsigns)"
  sub "Hunks (mudanças)"
  key "]g  /  [g"             "próximo / anterior hunk"
  key "<Leader>gl"            "blame da linha"
  key "<Leader>gL"            "blame do arquivo (toggle)"
  key "<Leader>gp"            "preview hunk"
  key "<Leader>gh"            "reset hunk"
  key "<Leader>gr"            "reset buffer"
  key "<Leader>gs"            "stage hunk"
  key "<Leader>gS"            "stage buffer"
  key "<Leader>gu"            "unstage hunk"
  key "<Leader>gd"            "diff this (vs index)"
  key "<Leader>gD"            "diff this ~ (vs HEAD)"
