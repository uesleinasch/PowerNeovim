  key "<Leader>th"            "terminal split horizontal"
  key "<Leader>tv"            "terminal split vertical"
  key "<Leader>tl"            "terminal lazygit (se instalado)"
  key "<Leader>tn"            "terminal node"
  key "<Leader>tp"            "terminal python"
  key "<Leader>tt"            "terminal btm/htop"
  sub "Dentro do terminal"
  key "<Esc><Esc>"            "sai do modo insert do terminal"
