  key "<Leader>ug"            "toggle signcolumn"
  key "<Leader>uf"            "toggle autoformat global"
  key "<Leader>uF"            "toggle autoformat do buffer"
  key "<Leader>ut"            "toggle treesitter highlight"
  key "<Leader>uu"            "toggle URL highlight"
  key "<Leader>uy"            "toggle syntax highlight"
  key "<Leader>uz"            "toggle zen mode"
