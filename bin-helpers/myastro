#!/usr/bin/env bash
# myastro — guia rápido de atalhos e recursos do AstroNvim (com config local)
# Uso: myastro [seção]
# Seções: leader, modes, motion, select, edit, textobj, registers, replace,
#         marks, macros, buffers, windows, files, search, lsp, diag, git,
#         term, harpoon, flash, surround, comments, session, ui, which,
#         packs, misc, prontos

set -euo pipefail

if [[ -t 1 ]]; then
  B=$'\033[1m'; D=$'\033[2m'; U=$'\033[4m'; R=$'\033[0m'
  C1=$'\033[38;5;141m'   # roxo (títulos)
  C2=$'\033[38;5;215m'   # laranja (subtítulos)
  C3=$'\033[38;5;114m'   # verde (atalhos)
  C4=$'\033[38;5;110m'   # azul (descrições)
  C5=$'\033[38;5;245m'   # cinza (notas)
else
  B=""; D=""; U=""; R=""; C1=""; C2=""; C3=""; C4=""; C5=""
fi

hr() { printf "${C5}%s${R}\n" "──────────────────────────────────────────────────────────────────────"; }
title() { printf "\n${C1}${B}▸ %s${R}\n" "$1"; hr; }
sub() { printf "\n${C2}${B}%s${R}\n" "$1"; }
key() { printf "  ${C3}%-26s${R} ${C4}%s${R}\n" "$1" "$2"; }
note() { printf "${C5}  %s${R}\n" "$1"; }

show_header() {
  printf "${C1}${B}\n"
  printf "  ███╗   ███╗██╗   ██╗     █████╗ ███████╗████████╗██████╗  ██████╗ \n"
  printf "  ████╗ ████║╚██╗ ██╔╝    ██╔══██╗██╔════╝╚══██╔══╝██╔══██╗██╔═══██╗\n"
  printf "  ██╔████╔██║ ╚████╔╝     ███████║███████╗   ██║   ██████╔╝██║   ██║\n"
  printf "  ██║╚██╔╝██║  ╚██╔╝      ██╔══██║╚════██║   ██║   ██╔══██╗██║   ██║\n"
  printf "  ██║ ╚═╝ ██║   ██║       ██║  ██║███████║   ██║   ██║  ██║╚██████╔╝\n"
  printf "  ╚═╝     ╚═╝   ╚═╝       ╚═╝  ╚═╝╚══════╝   ╚═╝   ╚═╝  ╚═╝ ╚═════╝ ${R}\n"
  printf "${C5}  Guia rápido — config em ~/.config/nvim/${R}\n"
  if command -v nvim >/dev/null 2>&1; then
    printf "${C5}  Neovim $(nvim --version 2>/dev/null | head -1 | awk '{print $2}')${R}\n"
  fi
  printf "${C5}  Leader = Espaço     LocalLeader = ,${R}\n"
}

section_leader() {
  title "Leader / descoberta"
  key "<Space>"               "Leader (prefixo principal de quase tudo)"
  key "<Space>?"              "buscar keymaps (snacks picker)"
  key "<Space>K"              "árvore completa de atalhos (which-key)"
