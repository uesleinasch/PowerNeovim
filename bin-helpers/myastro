  sub "Substituir / limpar"
  key ":%s/foo/bar/g"         "substitui em todo o arquivo"
  key ":%s/foo/bar/gc"        "idem com confirmação por ocorrência"
  key ":%s/\\<foo\\>/bar/g"   "palavra inteira"
